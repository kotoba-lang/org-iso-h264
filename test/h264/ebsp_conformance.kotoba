(ns h264.ebsp-conformance
  (:require [h264.rbsp :as rbsp]
            [h264.sps :as sps])
  (:export [main oversize-check]))

(def sps-type
  [:record :h264/sps
   [[:profile-idc :i64] [:level-idc :i64] [:width :i64] [:height :i64]
    [:frame-mbs-only :bool] [:chroma-format-idc :i64]
    [:pic-order-cnt-type :i64]]])
(def sps-result-type [:result [:alias sps-type] :keyword])
(def unescape-result-type [:result :vector-i64 :keyword])

(defn rejects? [data :vector-i64 expected :keyword] :bool
  (match-result (rbsp/unescape data) unescape-result-type
    (ok unexpected false)
    (err reason (if (= reason expected) true false))))

(defn oversize-check [data :vector-i64] :i64
  (if (rejects? data :nal-too-large) 42 1))

(defn main [] :i64
  (match-result
    (sps/parse-ebsp-baseline
      (vector-i64 103 66 192 10 217 4 123 1 16 0 0 3 0 16 0 0 3 0 160 241 34 100 128))
    sps-result-type
    (ok parsed
      (if (= 64 (record-get sps-type parsed :width))
        (if (= 48 (record-get sps-type parsed :height))
          (if (rejects? (vector-i64 103 0 0 3) :trailing-emulation-prevention)
            (if (rejects? (vector-i64 103 0 0 3 4) :invalid-emulation-prevention)
              (if (rejects? (vector-i64 103 0 0 2) :missing-emulation-prevention)
                (if (rejects? (vector-i64 103 0 0 256) :invalid-byte) 42 7)
                6)
              5)
            4)
          3)
        2))
    (err reason 1)))
