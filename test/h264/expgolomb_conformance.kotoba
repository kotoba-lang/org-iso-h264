(ns h264.expgolomb-conformance
  (:require [h264.expgolomb :as eg])
  (:export [main]))

(def read-pair-type [:vector [:i64 :i64]])
(def read-result-type [:result [:alias read-pair-type] :keyword])

(defn value-is?
  [result [:alias read-result-type] expected :i64 expected-index :i64] :bool
  (match-result result read-result-type
    (ok pair
      (if (= expected (hetero-vector-at read-pair-type pair 0))
        (if (= expected-index (hetero-vector-at read-pair-type pair 1)) true false)
        false))
    (err reason false)))

(defn error-is?
  [result [:alias read-result-type] expected :keyword] :bool
  (match-result result read-result-type
    (ok pair false)
    (err reason (if (= reason expected) true false))))

(defn main
  [] :i64
  (let [data (vector-i64 166)]
    (if (value-is? (eg/read-ue data 0) 0 1)
      (if (value-is? (eg/read-ue data 1) 1 4)
        (if (value-is? (eg/read-ue data 4) 2 7)
          (if (value-is? (eg/read-se data 1) 1 4)
            (if (value-is? (eg/read-se data 4) -1 7)
              (if (error-is? (eg/read-bit data 8) :eof) 42 6)
              5)
            4)
          3)
        2)
      1)))
