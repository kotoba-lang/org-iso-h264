(ns h264.sps-conformance
  (:require [h264.sps :as sps])
  (:export [main]))

(def sps-type
  [:record :h264/sps
   [[:profile-idc :i64] [:level-idc :i64] [:width :i64] [:height :i64]
    [:frame-mbs-only :bool] [:chroma-format-idc :i64]
    [:pic-order-cnt-type :i64]]])
(def sps-result-type [:result [:alias sps-type] :keyword])

(defn main [] :i64
  (match-result
    (sps/parse-baseline
      (vector-i64 103 66 192 10 217 4 123 1 16 0 0 0 16 0 0 0 160 241 34 100 128))
    sps-result-type
    (ok parsed
      (if (= 66 (record-get sps-type parsed :profile-idc))
        (if (= 64 (record-get sps-type parsed :width))
          (if (= 48 (record-get sps-type parsed :height)) 42 3)
          2)
        1))
    (err reason
      (if (= reason :eof) 90
        (if (= reason :unsupported-profile) 91
          (if (= reason :unsupported-poc-type) 92
            (if (= reason :invalid-dimensions) 93
              (if (= reason :invalid-nal-header) 94
                (if (= reason :reserved-bits-set) 95 99)))))))))
